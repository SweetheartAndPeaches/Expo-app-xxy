# ===========================================
# WebView 应用配置文件
# ===========================================
# 复制此文件为 .env 并修改配置值
# 配置项说明：
#   - 访问地址：EXPO_PUBLIC_WEBVIEW_URL
#   - 应用名称：EXPO_PUBLIC_APP_TITLE
#   - 应用语言：EXPO_PUBLIC_APP_LANGUAGE (hi=印地语, zh=中文)
#   - 应用图标：替换 client/assets/images/icon.png
# ===========================================

# 目标网页 URL（必需）
# 替换为你要展示的网页地址
EXPO_PUBLIC_WEBVIEW_URL=https://gamepay-app-six.vercel.app

# 应用名称（可选，默认为 "9INR"）
# 这个名称会显示在应用标题栏和通知设置指引中
EXPO_PUBLIC_APP_TITLE=9INR

# 应用语言（可选，默认为印地语 hi）
# hi = 印地语 (Hindi)
# zh = 中文 (Chinese)
EXPO_PUBLIC_APP_LANGUAGE=hi

# 应用包名（可选，仅 Android）
# 格式：com.company.appname
# 如果不设置，会使用默认的 com.anonymous.x{projectId}
# EXPO_PUBLIC_ANDROID_PACKAGE=com.mycompany.webviewapp
